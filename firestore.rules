rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /system_state/session_control {
      allow read, write: if isSignedIn();
    }

    match /system_state/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.resource.data.writeToken == 'action_v1'
        && request.resource.data.clientActionNonce is string
        && request.resource.data.clientActionNonce != resource.data.clientActionNonce;
    }

    match /bookings/{bookingId} {
      allow create: if isSignedIn()
        || request.resource.data.createdByUserId == 'public-web';
      allow read, update, delete: if isSignedIn();
    }

    match /payments/{paymentId} {
      allow read, write: if isSignedIn();
    }

    match /payment_status_overrides/{bookingId} {
      allow read, write: if isSignedIn();
    }

    match /authorization_policy/{docId} {
      allow read, write: if isSignedIn();
    }

    match /authorization_approvals/{approvalId} {
      allow read, write: if isSignedIn();
    }

    match /event_budgets/{docId} {
      allow read, write: if isSignedIn();
    }

    match /event_allocations/{docId} {
      allow read, write: if isSignedIn();
    }

    match /event_distributions/{docId} {
      allow read, write: if isSignedIn();
    }

    match /cash_transfers/{transferId} {
      allow read, write: if isSignedIn();
    }

    match /md_transfers/{docId} {
      allow read, write: if isSignedIn();
    }

    match /cash_distributions/{docId} {
      allow read, write: if isSignedIn();
    }

    match /inventory_items/{itemId} {
      allow read, write: if isSignedIn();
    }

    match /inventory_movements/{movementId} {
      allow read, write: if isSignedIn();
    }

    match /inventory_damages/{damageId} {
      allow read, write: if isSignedIn();
    }

    match /inventory_allocations/{allocationId} {
      allow read, write: if isSignedIn();
    }

    match /staff_users/{userId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /manager_messages/{messageId} {
      allow read, write: if isSignedIn();
    }

    match /document_form_outputs/{docId} {
      allow read, write: if isSignedIn();
    }

    match /cash_request_workflow/{docId} {
      allow read, write: if isSignedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
