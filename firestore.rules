rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /system_state/{docId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn()
        && request.resource.data.writeToken == 'action_v1';
    }

    match /bookings/{bookingId} {
      allow create: if isSignedIn()
        || request.resource.data.createdByUserId == 'public-web';
      allow read, update, delete: if isSignedIn();
    }

    match /staff_users/{userId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /manager_messages/{messageId} {
      allow read, write: if isSignedIn();
    }

    match /document_form_outputs/{docId} {
      allow read, write: if isSignedIn();
    }

    match /cash_request_workflow/{docId} {
      allow read, write: if isSignedIn();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
